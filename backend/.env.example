# Copy this file to ".env" and paste your own ComicVine API key.
# Get a free key: https://comicvine.gamespot.com/api/  (login -> "Get an API key")
COMICVINE_API_KEY=your_key_here

PORT=3000

# Storefront the "Buy" button searches. Default: Amazon US (English editions).
BUY_BASE_URL=https://www.amazon.com/s?k=