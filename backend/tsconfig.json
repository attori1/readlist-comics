{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "lib": ["ES2022"],
      "strict": true,
      "noUnusedLocals": false,
      "noUnusedParameters": false,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "types": ["node"],
      "outDir": "dist"
    },
    "include": ["src"]
  }